{
  "name": "jats",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean --parallel && find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "link": "turbo run link",
    "lint": "turbo run lint",
    "lint:format": "turbo run lint:format",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "publish": "bun run clean && bun run build -- --force && changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.1",
    "@types/node": "^20.3.3",
    "esbuild": "^0.17.19",
    "eslint": "^8.42.0",
    "eslint-config-curvenote": "^0.0.4",
    "prettier": "latest",
    "rimraf": "^5.0.1",
    "turbo": "latest",
    "typescript": "^5.1.3",
    "vitest": "^0.32.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.2.18"
}
